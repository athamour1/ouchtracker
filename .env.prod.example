# ── Database ──────────────────────────────────────────────────────────────────
DB_USER=fakcrm
DB_PASSWORD=change_me_strong_password
DB_NAME=fakcrm_db

# ── Frontend ──────────────────────────────────────────────────────────────────
# URL the browser uses to reach the API.
# Use /api when nginx proxies on the same domain (default, recommended).
# Use a full URL like https://api.your-domain.com/api for split deployments.
API_URL=/api

# ── Backend ───────────────────────────────────────────────────────────────────
# Must be the public URL the browser uses (for CORS). e.g. https://fakcrm.example.com
CORS_ORIGIN=http://localhost

# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_me_64_byte_hex_secret
JWT_EXPIRES_IN=8h

# ── Initial admin account (created once on first boot, skipped if already exists) ──
SEED_ADMIN_EMAIL=admin@fakcrm.local
SEED_ADMIN_PASSWORD=change_me_strong_admin_password
SEED_ADMIN_NAME=System Admin
